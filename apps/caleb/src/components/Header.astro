---
/* eslint-disable max-len */
import HeaderLink from './HeaderLink.astro';
import { SiteConfigService, getSocialIcon } from '@sferg989/astro-utils';
import type { SiteConfig } from '@sferg989/astro-utils';
import { SITE_TITLE } from '../consts';

// Initialize and fetch site config from CMS
SiteConfigService.initialize(import.meta.env.ASTRO_HYGRAPH_ENDPOINT);
const siteConfig: SiteConfig | null = await SiteConfigService.getSiteConfig('CALEB');

// Fallback values if CMS is unavailable
const siteTitle = siteConfig?.siteTitle ?? SITE_TITLE;
const navItems = siteConfig?.navigationItems ?? [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' }
];
const socialLinks = siteConfig?.socialLinks ?? [];
---

<header>
  <div class="shark-background">
    <div class="sunset-glow"></div>
    <div class="shark-fins"></div>
    <div class="orange-currents"></div>
  </div>
  <nav>
    <h2><a href="/" class="site-title">{siteTitle}</a></h2>
    <div class="internal-links">
      {navItems.map(item => (
        <HeaderLink href={item.href}>{item.label}</HeaderLink>
      ))}
    </div>
    {socialLinks.length > 0 && (
      <div class="social-links">
        {socialLinks.map(({ url, label, platform }) => {
          const icon = getSocialIcon(platform);
          return icon && (
            <a href={url} target="_blank" rel="noopener" class={platform.toLowerCase()}>
              <span class="sr-only">{label || `Visit ${platform}`}</span>
              <svg viewBox={icon.viewBox} aria-hidden="true" width="32" height="32">
                <fragment set:html={icon.path} />
              </svg>
            </a>
          );
        })}
      </div>
    )}
  </nav>
</header>
<style>
  header {
    background: rgba(26, 26, 26, 0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 107, 53, 0.4);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 1rem;
    margin-bottom: 2rem;
    box-shadow:
      0 0 20px rgba(255, 107, 53, 0.3),
      0 0 40px rgba(255, 140, 66, 0.2);
    overflow: hidden;
  }

  .shark-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .sunset-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      radial-gradient(3px 3px at 20px 30px, var(--accent-coral), rgba(0,0,0,0)),
      radial-gradient(4px 4px at 40px 70px, var(--accent-sunset), rgba(0,0,0,0)),
      radial-gradient(2px 2px at 50px 160px, var(--accent-orange), rgba(0,0,0,0)),
      radial-gradient(4px 4px at 90px 40px, var(--accent-coral), rgba(0,0,0,0)),
      radial-gradient(3px 3px at 130px 80px, var(--accent-sunset), rgba(0,0,0,0));
    background-repeat: repeat;
    background-size: 250px 250px;
    opacity: 0.4;
    animation: headerSunsetGlow 6s infinite;
  }

  .shark-fins {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background:
      radial-gradient(ellipse 40px 20px at 20% 60%, var(--accent-shark) 0%, transparent 70%),
      radial-gradient(ellipse 35px 18px at 80% 40%, var(--accent-fin) 0%, transparent 70%);
    background-size: 300px 200px, 250px 180px;
    background-repeat: no-repeat;
    opacity: 0;
    animation: headerSharkPatrol 8s linear infinite;
  }

  .orange-currents {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(
      ellipse at center,
      rgba(255, 107, 53, 0.12) 0%,
      rgba(255, 140, 66, 0.08) 50%,
      transparent 100%
    );
    animation: headerOrangeFlow 10s ease-in-out infinite;
    filter: blur(8px);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--content-width, 1200px);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .site-title {
    font-size: 2rem;
    font-weight: bold;
    text-decoration: none;
    background: linear-gradient(45deg, var(--accent-orange), var(--accent-coral));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 0 15px rgba(255, 107, 53, 0.6);
    transition: all 0.3s var(--shark-timing);
    position: relative;
  }

  .site-title:hover {
    transform: scale(1.05);
    text-shadow:
      0 0 20px rgba(255, 107, 53, 0.8),
      0 0 40px rgba(255, 140, 66, 0.6);
  }

  .internal-links a {
    position: relative;
    padding: 0.5rem 1rem;
    margin: 0 0.5rem;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: bold;
    transition: all 0.3s var(--shark-timing);
  }

  .internal-links a::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(45deg,
      rgba(255, 107, 53, 0.1),
      rgba(255, 140, 66, 0.1)
    );
    transform: skew(-15deg);
    z-index: -1;
    opacity: 0;
    transition: all 0.3s var(--shark-timing);
    border: 1px solid rgba(255, 107, 53, 0.1);
    border-radius: 4px;
  }

  .internal-links a:hover {
    color: var(--accent-orange);
    text-shadow:
      0 0 8px var(--accent-orange),
      0 0 16px var(--accent-coral);
    transform: translateY(-2px);
  }

  .internal-links a:hover::before {
    opacity: 1;
    border-color: rgba(255, 107, 53, 0.4);
    box-shadow:
      0 0 15px rgba(255, 107, 53, 0.3),
      0 0 30px rgba(255, 140, 66, 0.2);
  }

  @keyframes headerSunsetGlow {
    0%, 100% {
      opacity: 0.4;
      transform: scale(1);
    }
    50% {
      opacity: 0.7;
      transform: scale(1.1);
    }
  }

  @keyframes headerSharkPatrol {
    0% {
      opacity: 0;
      background-position: -100px 60%, 300px 40%;
    }
    25% {
      opacity: 0.6;
      background-position: 200px 65%, 500px 45%;
    }
    50% {
      opacity: 0.3;
      background-position: 500px 70%, 800px 50%;
    }
    75% {
      opacity: 0.6;
      background-position: 800px 55%, 1100px 35%;
    }
    100% {
      opacity: 0;
      background-position: 1100px 60%, 1400px 40%;
    }
  }

  @keyframes headerOrangeFlow {
    0%, 100% {
      opacity: 0.3;
      transform: scale(1) rotate(0deg);
    }
    50% {
      opacity: 0.4;
      transform: scale(1.1) rotate(3deg);
    }
  }

  .social-links {
    display: flex;
    gap: 0.5rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 107, 53, 0.2);
    border: 1px solid rgba(255, 107, 53, 0.3);
    border-radius: 50%;
    color: var(--accent-orange);
    transition: all 0.3s var(--shark-timing);
  }

  .social-links a:hover {
    transform: scale(1.1);
    background: rgba(255, 107, 53, 0.3);
    box-shadow: 0 0 15px rgba(255, 107, 53, 0.5);
  }

  .social-links a.twitter:hover {
    background: rgba(29, 161, 242, 0.3);
    border-color: #1DA1F2;
    color: #1DA1F2;
  }

  .social-links a.instagram:hover {
    background: rgba(225, 48, 108, 0.3);
    border-color: #E1306C;
    color: #E1306C;
  }

  .social-links a.linkedin:hover {
    background: rgba(0, 119, 181, 0.3);
    border-color: #0077B5;
    color: #0077B5;
  }

  .social-links a.youtube:hover {
    background: rgba(255, 0, 0, 0.3);
    border-color: #FF0000;
    color: #FF0000;
  }

  .social-links a.tiktok:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: #fff;
    color: #fff;
  }

  .social-links a.mastodon:hover {
    background: rgba(99, 100, 255, 0.3);
    border-color: #6364FF;
    color: #6364FF;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
