---
import Layout from '@layouts/Layout.astro';
import PageBody from '@components/pageBody.astro';
import PageHero from '@components/pageHero.astro';
import { SoccerService } from '../../services/soccerService';
import { optimizeImages } from '@sferg989/astro-utils/image-optimization';
import { formatGameDate } from '@sferg989/astro-utils';
import type { SoccerGame } from '@sferg989/astro-utils';

export async function getStaticPaths() {
  const endpoint = import.meta.env.ASTRO_HYGRAPH_ENDPOINT;
  SoccerService.initialize(endpoint);
  const { soccerGames } = await SoccerService.getAllGames();

  return soccerGames.map((game: SoccerGame) => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

const { game } = Astro.props;
const { soccerGame: fullGame } = await SoccerService.getGameBySlug(game.slug);

if (fullGame?.body?.html) {
  fullGame.body.html = await optimizeImages(fullGame.body.html);
}
---

<Layout
  title={fullGame.title}
  description={fullGame.metaDescription ?? fullGame.excerpt ?? ''}
  heroImage={fullGame.heroImage}
  publishedAt={fullGame.gameDate ?? ''}
  updatedAt={fullGame.updatedAt ?? ''}
  keywords={fullGame.keywords ?? ''}
  type="article"
>
  <PageHero title={fullGame.title} heroImage={fullGame.heroImage ?? undefined} />

  <div class="game-meta">
    {fullGame.gameDate && (
      <div class="meta-item">
        <span class="meta-label">Date</span>
        <span class="meta-value">{formatGameDate(fullGame.gameDate)}</span>
      </div>
    )}
    {fullGame.opponent && (
      <div class="meta-item">
        <span class="meta-label">Opponent</span>
        <span class="meta-value">{fullGame.opponent}</span>
      </div>
    )}
    {fullGame.score && (
      <div class="meta-item">
        <span class="meta-label">Score</span>
        <span class="meta-value score">{fullGame.score}</span>
      </div>
    )}
    {fullGame.location && (
      <div class="meta-item">
        <span class="meta-label">Location</span>
        <span class="meta-value">{fullGame.location}</span>
      </div>
    )}
    {fullGame.season && (
      <div class="meta-item">
        <span class="meta-label">Season</span>
        <span class="meta-value">{fullGame.season}</span>
      </div>
    )}
  </div>

  <PageBody content={fullGame.body} highlights={fullGame.highlights ?? []} />
</Layout>

<style>
  .game-meta {
    max-width: 720px;
    margin: 0 auto 2rem;
    padding: 1rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    background: var(--meta-bg, rgba(255, 255, 255, 0.05));
    border-radius: 12px;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted, #888);
  }

  .meta-value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-color, #fff);
  }

  .meta-value.score {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--accent-color, #ffd700);
  }
</style>
