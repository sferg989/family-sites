---
import Layout from '@layouts/Layout.astro';
import { ContentListing } from '@sferg989/astro-utils';
import { SoccerService } from '../../services/soccerService';
import type { ContentListItem } from '@sferg989/astro-utils';

const endpoint = import.meta.env.ASTRO_HYGRAPH_ENDPOINT;
SoccerService.initialize(endpoint);

const { soccerGames } = await SoccerService.getAllGames();

const formatGameMeta = (game: typeof soccerGames[0]): string => {
  const parts: string[] = [];
  if (game.opponent) parts.push(`vs ${game.opponent}`);
  if (game.score) parts.push(game.score);
  return parts.join(' \u2022 ');
};

const items: ContentListItem[] = soccerGames.map(game => ({
  title: game.title,
  slug: game.slug,
  excerpt: game.excerpt,
  heroImage: game.heroImage,
  publishedAt: game.gameDate,
  meta: formatGameMeta(game)
}));
---

<Layout
  title="Soccer"
  description="Soccer games and highlights"
  type="website"
>
  <div class="soccer-landing">
    <header class="page-header">
      <h1>Soccer</h1>
      <p class="page-description">Game recaps and highlights</p>
    </header>

    <ContentListing items={items} basePath="/soccer" columns={2} />
  </div>
</Layout>

<style>
  .soccer-landing {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .page-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem;
    background: linear-gradient(104deg,
      var(--stripe-color-1, #4a90d9) 0%,
      var(--stripe-color-2, #67b26f) 100%
    );
    border-radius: 15px;
    color: white;
  }

  .page-header h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 0.5rem 0;
    text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.2);
  }

  .page-description {
    margin: 0;
    font-size: 1.2rem;
    opacity: 0.9;
  }
</style>
