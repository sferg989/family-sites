---
import Layout from '@layouts/Layout.astro';
import { SoccerService } from '../../services/soccerService';
import { optimizeImages } from '@sferg989/astro-utils/image-optimization';
import { VideoDisplay, formatGameDate } from '@sferg989/astro-utils';
import type { SoccerGame } from '@sferg989/astro-utils';
import { SITE_TITLE } from '../../consts';

export async function getStaticPaths() {
  const endpoint = import.meta.env.ASTRO_HYGRAPH_ENDPOINT;
  SoccerService.initialize(endpoint);
  const { soccerGames } = await SoccerService.getAllGames();

  return soccerGames.map((game: SoccerGame) => ({
    params: { slug: game.slug },
    props: { game },
  }));
}

const { game } = Astro.props;
const { soccerGame: fullGame } = await SoccerService.getGameBySlug(game.slug);

if (fullGame?.body?.html) {
  fullGame.body.html = await optimizeImages(fullGame.body.html);
}

const pageTitle = `${fullGame.title} | ${SITE_TITLE}`;
---

<Layout
  title={pageTitle}
  description={fullGame.metaDescription || fullGame.excerpt}
  heroImage={fullGame.heroImage}
  publishedAt={fullGame.gameDate}
  updatedAt={fullGame.updatedAt}
  keywords={fullGame.keywords}
>
  <div class="soccer-game">
    {fullGame.heroImage && (
      <div class="hero-image">
        <img
          src={fullGame.heroImage.url}
          alt={fullGame.title}
          loading="eager"
        />
      </div>
    )}

    <div class="content-container">
      <header class="game-header">
        <h1>{fullGame.title}</h1>
        <hr />
      </header>

      <div class="game-meta">
        {fullGame.gameDate && (
          <div class="meta-item">
            <span class="meta-label">Date</span>
            <span class="meta-value">{formatGameDate(fullGame.gameDate)}</span>
          </div>
        )}
        {fullGame.opponent && (
          <div class="meta-item">
            <span class="meta-label">Opponent</span>
            <span class="meta-value">{fullGame.opponent}</span>
          </div>
        )}
        {fullGame.score && (
          <div class="meta-item">
            <span class="meta-label">Score</span>
            <span class="meta-value score">{fullGame.score}</span>
          </div>
        )}
        {fullGame.location && (
          <div class="meta-item">
            <span class="meta-label">Location</span>
            <span class="meta-value">{fullGame.location}</span>
          </div>
        )}
        {fullGame.season && (
          <div class="meta-item">
            <span class="meta-label">Season</span>
            <span class="meta-value">{fullGame.season}</span>
          </div>
        )}
      </div>

      {fullGame.body?.html && (
        <div class="game-body" set:html={fullGame.body.html} />
      )}

      {(fullGame.highlights?.length ?? 0) > 0 && (
        <VideoDisplay videos={fullGame.highlights ?? []} title="Highlights" />
      )}

      <nav class="back-link">
        <a href="/soccer/" class="back-button">
          &larr; Back to Soccer
        </a>
      </nav>
    </div>
  </div>
</Layout>

<style>
  .soccer-game {
    margin-bottom: 2rem;
  }

  .hero-image {
    width: 100%;
    max-height: 60vh;
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .content-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .game-header {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: linear-gradient(104deg,
      var(--stripe-color-1, #ff6b6b) 0%,
      var(--stripe-color-2, #4ecdc4) 100%
    );
    border-radius: 15px;
    color: white;
  }

  .game-header h1 {
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    margin: 0;
    text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.2);
  }

  .game-header hr {
    border: none;
    height: 4px;
    background: var(--accent-color, #ffe66d);
    margin: 1rem 0 0;
    border-radius: 2px;
  }

  .game-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
    padding: 1rem;
    background: var(--accent-color, #ffe66d);
    border-radius: 12px;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .meta-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted, #666);
  }

  .meta-value {
    font-size: 1rem;
    font-weight: 500;
    color: var(--text-color, #333);
  }

  .meta-value.score {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--accent, #2337ff);
  }

  .game-body {
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .game-body :global(p) {
    margin-bottom: 1.5rem;
  }

  .back-link {
    margin-top: 2rem;
    text-align: center;
  }

  .back-button {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    color: var(--text-color, #333);
    text-decoration: none;
    border: 2px solid var(--accent-color, #ffe66d);
    border-radius: 8px;
    transition: all 0.2s ease;
  }

  .back-button:hover {
    background: var(--accent-color, #ffe66d);
  }
</style>
